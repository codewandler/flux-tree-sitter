{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "flux",
      "camelcase": "Flux",
      "scope": "source.flux",
      "path": ".",
      "file-types": [
        "flux"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injections": [
        "queries/injections.scm"
      ],
      "locals": [
        "queries/locals.scm"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT OR Apache-2.0",
    "description": "Flux-Lang grammar for tree-sitter",
    "authors": [
      {
        "name": "codewandler"
      }
    ],
    "links": {
      "repository": "https://github.com/codewandler/flux-tree-sitter"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
